@model IEnumerable<MVC14.ViewModels.ProductVM>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int totalPages = (int)(ViewData["TotalPages"] ?? 1);
    int activePage = (int)(ViewData["ActivePage"] ?? 1);
    int indexPage = 1;
}

<h1>Index</h1>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group mb-2">
        <input type="text"
               name="searchString"
               value="@ViewData["CurrentFilter"]"
               class="form-control"
               placeholder="Nhập tên sản phẩm..."
               onchange="this.form.submit()" />
    </div>

    <div class="row mb-3">
        <div class="col">
            <select class="form-select"
                    name="categoryId"
                    asp-items="ViewBag.Categories"
                    onchange="this.form.submit()">
                <option value="0">-- Tất cả loại --</option>
            </select>
        </div>

        <div class="col">
            <select class="form-select"
                    name="supplierId"
                    asp-items="ViewBag.Suppliers"
                    onchange="this.form.submit()">
                <option value="0">-- Tất cả NCC --</option>
            </select>
        </div>

        <div class="col">
            <select class="form-select"
                    name="orderBy"
                    asp-items="ViewBag.OrderTypes"
                    onchange="this.form.submit()">
                <option value="">-- Sắp xếp --</option>
            </select>
        </div>
    </div>
</form>

@await Html.PartialAsync("_ProductGrid", Model)

<nav aria-label="Page navigation example">
    <ul class="pagination justify-content-center">
        @if (activePage > 1)
        {
            <li class="page-item">
                <a class="page-link"
                       aria-label="Previous"
                       asp-route-page="@(activePage > 1 ? activePage - 1 : 1)">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>
        }
        @for (; indexPage <= totalPages; indexPage++)
        {
            if (indexPage == activePage)
            {
                <li class="page-item active" aria-current="page">
                    <span class="page-link">@indexPage</span>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link"
                           asp-route-page="@indexPage">
                        @indexPage
                    </a>
                </li>
            }
        }
        @if (activePage < totalPages)
        {
            <li class="page-item">
                <a class="page-link"
                       aria-label="Next"
                       asp-route-page="@(activePage < totalPages ? activePage + 1 : totalPages)">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        }
    </ul>
</nav>
