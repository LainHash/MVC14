<!-- Product Grid -->
<div class="products-grid">
    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var product in Model)
            {
                <div class="col-lg-4 col-md-6 col-sm-12">
                    <div class="product-card h-100" data-product-id="@product.ProductId">
                        <!-- Product Image -->
                        <div class="product-image-wrapper position-relative overflow-hidden">
                            <img src="@(product.ImageUrl ?? Url.Content("~/img/NotFoundImage.png"))"
                                 alt="@product.ProductName"
                                 class="product-image img-fluid w-100"
                                 loading="lazy" />
                            <div class="product-overlay">
                                <a asp-action="Details" asp-route-id="@product.ProductId"
                                       class="btn btn-primary btn-sm rounded-pill">
                                    <i class="fas fa-eye me-2"></i>Chi tiết
                                </a>
                            </div>
                            <div class="stock-badge">
                                <span class="badge @(product.UnitsInStock > 0 ? "bg-success" : "bg-danger")">
                                    @if (product.UnitsInStock > 0)
                                    {
                                        <span>Còn hàng (@product.UnitsInStock)</span>
                                    }
                                    else
                                    {
                                        <span>Hết hàng</span>
                                    }
                                </span>
                            </div>
                        </div>

                        <!-- Product Info -->
                        <div class="product-body p-4">
                            <div class="product-category mb-2">
                                <small class="text-secondary fw-bold">
                                    <i class="fas fa-tag me-1"></i>@product.CategoryName
                                </small>
                            </div>

                            <h5 class="product-title mb-3 text-truncate" title="@product.ProductName">
                                @product.ProductName
                            </h5>

                            <p class="product-description text-secondary small mb-3 text-truncate-2">
                                @if (!string.IsNullOrEmpty(product.Description))
                                {
                                    @Html.Raw(product.Description.Length > 80 ? product.Description.Substring(0, 80) + "..." : product.Description)
                                }
                                else
                                {
                                    <span class="text-muted">Không có mô tả</span>
                                }
                            </p>

                            <div class="product-supplier mb-3">
                                <small class="text-muted">
                                    <i class="fas fa-store me-1"></i>@product.CompanyName
                                </small>
                            </div>

                            <div class="product-footer d-flex justify-content-between align-items-center">
                                <div class="product-price">
                                    <h6 class="price-value text-primary fw-bold text-nowrap">
                                        @product.UnitPrice.ToString("N0") đ
                                    </h6>
                                </div>
                                <a asp-controller="Cart" asp-action="Add" asp-route-productSkuId="@product.ProductSkuId"
                                       class="btn btn-outline-primary btn-sm rounded-circle"
                                       title="Thêm vào giỏ hàng">
                                    <i class="fas fa-shopping-cart"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5" role="alert">
            <i class="fas fa-inbox fa-3x mb-3 d-block text-muted"></i>
            <h5>Không tìm thấy sản phẩm nào</h5>
            <p class="text-secondary">Hãy thử thay đổi các bộ lọc để tìm sản phẩm bạn muốn</p>
        </div>
    }
</div>